{
  "name": "ngern-ngern-tong-tong-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "build:lambda": "esbuild src/lambda.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/lambda/index.mjs",
    "db:migrate:local": "wrangler d1 migrations apply ngern-ngern-tong-tong-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply ngern-ngern-tong-tong-db --remote",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@hono/standard-validator": "^0.2.3",
    "@scalar/hono-api-reference": "^0.11.9",
    "hono": "^4.8.0",
    "hono-openapi": "^1.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "esbuild": "^0.25.5",
    "typescript": "^5.8.0",
    "wrangler": "^4.23.0"
  }
}
